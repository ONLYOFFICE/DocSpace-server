      "secret": "docspace-secret",
      "redirectUris": [
        "http://localhost:8092/*",
        "http://localhost:5000/*"
      ],
      "webOrigins": [
        "http://localhost:8092",
        "http://localhost:5000"
      ],
      "defaultClientScopes": [
        "web-origins",
        "acr",
        "profile",
        "roles",
        "email"
      ],
      "optionalClientScopes": [
        "address",
        "phone",
        "offline_access",
        "microprofile-jwt"
      ]
    },
    {
      "clientId": "http://localhost:8092/sso/metadata",
      "name": "DocSpace SAML",
      "description": "ONLYOFFICE DocSpace SAML SSO client",
      "enabled": true,
      "protocol": "saml",
      "frontchannelLogout": true,
      "attributes": {
        "saml.authnstatement": "true",
        "saml.server.signature": "true",
        "saml.assertion.signature": "true",
        "saml.force.post.binding": "true",
        "saml_name_id_format": "persistent",
        "saml.multivalued.roles": "false",
        "saml.encrypt": "false",
        "saml_signature_canonicalization_method": "http://www.w3.org/2001/10/xml-exc-c14n#",
        "saml.client.signature": "false"
      },
      "redirectUris": [
        "http://localhost:8092/sso/acs",
        "http://localhost:8092/sso/slo/callback"
      ],
      "adminUrl": "http://localhost:8092/sso/acs",
      "protocolMappers": [
        {
          "name": "email",
          "protocol": "saml",
          "protocolMapper": "saml-user-property-mapper",
          "consentRequired": false,
          "config": {
            "attribute.nameformat": "Basic",
            "user.attribute": "email",
            "attribute.name": "mail"
          }
        },
        {
          "name": "firstName",
          "protocol": "saml",
          "protocolMapper": "saml-user-property-mapper",
          "consentRequired": false,
          "config": {
            "attribute.nameformat": "Basic",
            "user.attribute": "firstName",
            "attribute.name": "givenName"
          }
        },
        {
          "name": "lastName",
          "protocol": "saml",
          "protocolMapper": "saml-user-property-mapper",
          "consentRequired": false,
          "config": {
            "attribute.nameformat": "Basic",
            "user.attribute": "lastName",
            "attribute.name": "sn"
          }
        }
      ]
    },
    {
      "clientId": "openproject",
      "name": "OpenProject",
      "description": "OpenProject SSO client via DocSpace Keycloak",
      "enabled": true,
      "publicClient": false,
      "standardFlowEnabled": true,
      "implicitFlowEnabled": false,
      "directAccessGrantsEnabled": false,
      "serviceAccountsEnabled": false,
      "protocol": "openid-connect",
      "secret": "openproject-secret",
      "redirectUris": [
        "http://localhost:8083/*"
      ],
      "webOrigins": [
        "http://localhost:8083"
      ],
      "defaultClientScopes": [
        "web-origins",
        "acr",
        "profile",
        "roles",
        "email"
      ],
      "optionalClientScopes": [
        "address",
        "phone",
        "offline_access",
        "microprofile-jwt"
      ]
    }
