{
  "$schema": "./node_modules/@openapitools/openapi-generator-cli/config.schema.json",
  "spaces": 2,
  "generator-cli": {
    "version": "7.19.0"
  },
  "generatorName": "my-ruby",
  "inputSpec": "./json/api-docs.json",
  "outputDir": "ruby-sdk",
  "additionalProperties": {
    "gemName": "docspace-api-sdk",
    "moduleName": "DocspaceApiSdk",
    "gemVersion": "3.7.0",
    "gemLicense": "Apache-2.0",
    "library": "typhoeus",
    "gemAuthor": "Ascensio System SIA <integration@onlyoffice.com> (https://www.onlyoffice.com)",
    "gemHomepage": "https://www.onlyoffice.com",
    "gemDescription": "A simple Ruby SDK for integrating with the ONLYOFFICE DocSpace API"
  }
}