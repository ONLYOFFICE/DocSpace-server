{
  "$schema": "./node_modules/@openapitools/openapi-generator-cli/config.schema.json",
  "spaces": 2,
  "generator-cli": {
    "version": "7.19.0"
  },
  "generatorName": "my-csharp",
  "inputSpec": "./json/api-docs.json",
  "outputDir": "ClientNet",
  "additionalProperties": {
    "packageName": "DocSpace.API.SDK",
    "packageVersion": "3.7.0",
    "licenseName": "Apache-2.0",
    "repositoryUrl": "https://github.com/ONLYOFFICE/docspace-api-sdk-csharp",
    "library": "httpclient",
    "targetFramework": "net10.0",
    "useOneOfDiscriminatorLookup": false,
    "excludeTests": true,
    "zeroBasedEnums": true,
    "packageTitle": "DocSpace.API.SDK",
    "outputFolder": "../../../../../sdk/docspace-api-sdk-csharp",
    "packageDescription": "A simple CSharp SDK for integrating with the ONLYOFFICE DocSpace API",
    "seealsoBaseUrl": "https://api.onlyoffice.com/docspace/api-backend/usage-api",
    "example": true,
    "readMe": "README.mustache"
  }
}