{
  "$schema": "./node_modules/@openapitools/openapi-generator-cli/config.schema.json",
  "spaces": 2,
  "generator-cli": {
    "version": "7.19.0"
  },
  "generatorName": "my-php",
  "inputSpec": "./json/billing-api.json",
  "outputDir": "php-sdk",
  "additionalProperties": {
    "packageName": "onlyoffice/billing-api-sdk",
    "packageVersion": "3.6.0",
    "licenseName": "Apache-2.0",
    "repositoryUrl": "https://github.com/ONLYOFFICE/billing-api-sdk-php",
    "library": "guzzle",
    "excludeTests": true,
    "outputFolder": "generated-sdk/billing-api-sdk-php",
    "packageDescription": "A simple PHP SDK for integrating with the ONLYOFFICE Billing API",
    "packageKeywords": [
      "onlyoffice",
      "billing",
      "sdk"
    ],
    "homepage": "https://www.onlyoffice.com",
    "supportEmail": "support@onlyoffice.com",
    "supportForum": "https://forum.onlyoffice.com/",
    "authorsName": "Ascensio System SIA",
    "seealsoBaseUrl": "https://api.onlyoffice.com/billing",
    "readMe": "README_Billing.mustache"
  }
}