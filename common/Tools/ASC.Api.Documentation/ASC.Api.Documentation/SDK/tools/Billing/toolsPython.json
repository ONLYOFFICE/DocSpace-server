{
  "$schema": "./node_modules/@openapitools/openapi-generator-cli/config.schema.json",
  "spaces": 2,
  "generator-cli": {
    "version": "7.19.0"
  },
  "generatorName": "my-python",
  "inputSpec": "./json/billing-api.json",
  "outputDir": "python-sdk",
  "additionalProperties": {
    "packageName": "billing_api_sdk",
    "packageVersion": "3.6.0",
    "licenseName": "Apache-2.0",
    "repositoryUrl": "https://github.com/ONLYOFFICE/billing-api-sdk-python",
    "excludeTests": true,
    "outputFolder": "generated-sdk/billing-api-sdk-python",
    "packageDescription": "A simple Python SDK for integrating with the ONLYOFFICE Billing API",
    "example": false,
    "readMe": "README_Billing.mustache"
  },
  "reservedWords": ["None"]
}