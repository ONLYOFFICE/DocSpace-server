{
  "$schema": "./node_modules/@openapitools/openapi-generator-cli/config.schema.json",
  "spaces": 2,
  "generator-cli": {
    "version": "7.19.0"
  },
  "generatorName": "my-typescript-axios",
  "inputSpec": "./json/billing-api.json",
  "outputDir": "typescript-sdk",
  "additionalProperties": {
    "packageName": "@onlyoffice/billing-api-sdk",
    "packageVersion": "3.6.0",
    "licenseName": "Apache-2.0",
    "repositoryUrl": "https://github.com/ONLYOFFICE/billing-api-sdk-typescript",
    "withSeparateModelsAndApi": true,
    "modelPackage": "models",
    "apiPackage": "api", 
    "axiosVersion": "1.13.5",
    "outputFolder": "generated-sdk/billing-api-sdk-typescript",
    "packageDescription": "A simple TypeScript SDK for integrating with the ONLYOFFICE DocSpace API",
    "packageKeywords": [
      "onlyoffice",
      "docspace",
      "sdk"
    ],
    "homepage": "https://www.onlyoffice.com",
    "supportEmail": "support@onlyoffice.com",
    "authorsName": "Ascensio System SIA <integration@onlyoffice.com> (https://www.onlyoffice.com)",
    "seealsoBaseUrl": "https://api.onlyoffice.com/billing",
    "readMe": "README_Billing.mustache"
  }
}