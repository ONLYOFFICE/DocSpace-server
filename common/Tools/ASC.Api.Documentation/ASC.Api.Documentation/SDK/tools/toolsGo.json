{
  "$schema": "./node_modules/@openapitools/openapi-generator-cli/config.schema.json",
  "spaces": 2,
  "generator-cli": {
    "version": "7.19.0"
  },
  "generatorName": "my-go",
  "inputSpec": "./json/api-docs.json",
  "outputDir": "go-sdk",
  "additionalProperties": {
    "packageName": "docspace_api_sdk",
    "packageVersion": "3.6.0",
    "licenseName": "Apache-2.0",
    "repositoryUrl": "https://github.com/ONLYOFFICE/docspace-api-sdk-go",
    "gitHost": "github.com",
    "gitUserId": "ONLYOFFICE",
    "gitRepoId": "docspace-api-sdk-go",
    "excludeTests": true,
    "enumClassPrefix": true
  }
}
