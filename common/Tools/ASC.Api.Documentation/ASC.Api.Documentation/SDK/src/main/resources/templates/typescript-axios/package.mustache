{
  "name": "{{packageName}}",
  "version": "{{packageVersion}}",
  "description": "{{packageDescription}}",
  "homepage": "{{homepage}}",
  "author": "{{{authorsName}}}",
  "maintainers": [
    "{{{authorsName}}}"
  ],
  "repository": {
    "type": "git",
    "url": "git+{{repositoryUrl}}.git"
  },
  "bugs": {
    "url": "{{repositoryUrl}}/issues",
    "email": "{{supportEmail}}"
  },
  "keywords": [
  {{#packageKeywords}}
    "{{.}}"{{^-last}},{{/-last}}
  {{/packageKeywords}}
  ],
  "license": "{{licenseName}}",
  "main": "./dist/index.js",
  "typings": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
{{#supportsES6}}
  "module": "./dist/esm/index.js",
  "sideEffects": false,
{{/supportsES6}}
  "scripts": {
    "build": "tsc{{#supportsES6}} && tsc -p tsconfig.esm.json{{/supportsES6}}",
    "prepare": "npm run build"
  },
  "dependencies": {
    "axios": "{{axiosVersion}}"
  },
  "devDependencies": {
    "@types/node": "12.11.5 - 12.20.42",
    "typescript": "^4.0 || ^5.0"
  }
}
