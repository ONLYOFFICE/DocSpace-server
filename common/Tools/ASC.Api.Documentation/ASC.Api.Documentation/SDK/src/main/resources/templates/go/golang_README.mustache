    {{packageName}} "{{gitHost}}/{{gitUserId}}/{{gitRepoId}}{{#isGoSubmodule}}/{{packageName}}{{/isGoSubmodule}}"
)

func main() {
    cfg := {{packageName}}.NewConfiguration()
    cfg.Servers = {{packageName}}.ServerConfigurations{
        {
            URL: "https://your-docspace.onlyoffice.com",
            Description: "Default server",
        },
    }

    client := {{packageName}}.NewAPIClient(cfg)
    ctx := context.Background()

    {{#authMethods}}
