    {{/authMethods}}

    {{#apiInfo}}{{#apis}}{{#-first}}{{#operations}}{{#operation}}{{#-first}}
    {{#requiredParams}}{{{paramName}}} := {{{example}}} // {{{description}}}
    {{/requiredParams}}

