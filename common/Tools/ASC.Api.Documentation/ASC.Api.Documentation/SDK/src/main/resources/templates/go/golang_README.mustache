    {{#optionalParams}}
    // Optional parameter available: {{paramName}} ({{{dataType}}}){{#example}}, example: {{{example}}}{{/example}} // {{{description}}}
    {{/optionalParams}}

    response, httpResponse, err := request.Execute()
    if err != nil {
        fmt.Printf("Error when calling {{{classname}}}.{{{operationId}}}: %v\n", err)
        if httpResponse != nil {
            fmt.Printf("HTTP response: %s\n", httpResponse.Status)
        }
        return
    }

    fmt.Printf("Response from `{{{operationId}}}`: %v\n", response)
    {{/-first}}{{/operation}}{{/operations}}{{/-first}}{{/apis}}{{/apiInfo}}
}
