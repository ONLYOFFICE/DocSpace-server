{
  "info": {
    "name": "{{{packageName}}}",
    "description": {
      "content": "{{packageDescription}}",
      "type": "text/markdown"
    },
    "version": "{{{packageVersion}}}",
    "schema": "{{postmanSchema}}",
    "_postman_id": "{{postmanId}}"
  },
  "item": [
    {{#tagGroups}}
    {
      "name": "{{name}}",
      "description": "{{{description}}}",
      "item": [
        {{#children}}
        {{#isSelf}}
        {{#operations}}
        {{>item}}{{^-last}},{{/-last}}
        {{/operations}}
        {{/isSelf}}
        {{^isSelf}}
        {
          "name": "{{name}}",
          "description": "{{{description}}}",
          "item": [
            {{#operations}}
            {{>item}}{{^-last}},{{/-last}}
            {{/operations}}
          ]
        }{{^-last}},{{/-last}}
        {{/isSelf}}
        {{/children}}
      ]
    }{{^-last}},{{/-last}}
    {{/tagGroups}}
  ],
  {{#authMethods}}{{#-first}}{{#isApiKey}}"auth": {
    "type": "apikey",
    "apikey": [
      {
        "key": "value",
        "value": "{{=<% %>=}}{{<%={{ }}=%>{{keyParamName}}{{=<% %>=}}}}<%={{ }}=%>",
        "type": "string"
      },
      {
        "key": "key",
        "value": "{{keyParamName}}",
        "type": "string"
      }
    ]
  },{{/isApiKey}}{{#isBasicBasic}}"auth": {
    "type": "basic",
    "basic": [
      {
        "key": "username",
        "value": "{{=<% %>=}}{{<%={{ }}=%>USERNAME{{=<% %>=}}}}<%={{ }}=%>",
        "type": "string"
      },
      {
        "key": "password",
        "value": "{{=<% %>=}}{{<%={{ }}=%>PASSWORD{{=<% %>=}}}}<%={{ }}=%>",
        "type": "string"
      }
    ]
  },{{/isBasicBasic}}{{/-first}}{{/authMethods}}
  "variable": [{{#servers}}{{#-first}}
    {
      "key": "baseUrl",
      "value": "{{url}}",
      "type": "string"
    }{{/-first}}{{/servers}}{{#authMethods}}{{#isApiKey}},
    {
      "key": "{{keyParamName}}",
      "value": "",
      "type": "string"
    }{{/isApiKey}}{{/authMethods}}{{#apiInfo}}{{#apis}}{{#vendorExtensions}}{{#-first}}{{#variables}}{{#-first}},{{/-first}}
    {
      {{! use first element in vendorExtensions }}
      "key": "{{name}}",
      "value": "{{defaultValue}}",
      "type": "{{type}}"
    }{{^-last}},{{/-last}}{{/variables}}{{/-first}}{{/vendorExtensions}}{{/apis}}{{/apiInfo}}
  ]
}