{
    "name": "{{{packageName}}}",
    "type": "library",
    "version": "{{{packageVersion}}}",
    "description": "{{packageDescription}}",
    "keywords": [
    {{#packageKeywords}}
        "{{.}}"{{^-last}},{{/-last}}
    {{/packageKeywords}}
    ],
    "homepage": "{{homepage}}",
    "license": "{{{licenseName}}}",
    "authors": [
        {
            "name": "{{authorsName}}",
            "homepage": "{{homepage}}"
        }
    ],
    "support": {
        "issues": "{{repositoryUrl}}/issues",
        "source": "{{repositoryUrl}}",
        "email": "{{supportEmail}}",
        "forum": "{{supportForum}}"
    },
    "require": {
        "php": "^8.1",
        "ext-curl": "*",
        "ext-json": "*",
        "ext-mbstring": "*",
        "guzzlehttp/guzzle": "^7.3",
        "guzzlehttp/psr7": "^1.7 || ^2.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^8.0 || ^9.0",
        "friendsofphp/php-cs-fixer": "^3.5"
    },
    "autoload": {
        "psr-4": { "{{{escapedInvokerPackage}}}\\" : "{{{srcBasePath}}}/" }
    },
    "autoload-dev": {
        "psr-4": { "{{{escapedInvokerPackage}}}\\Test\\" : "{{{testBasePath}}}/" }
    }
}
