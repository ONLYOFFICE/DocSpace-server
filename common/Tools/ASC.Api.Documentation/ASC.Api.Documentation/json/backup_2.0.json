  "components": {
    "schemas": {
      "BackupDto": {
        "type": "object",
        "properties": {
          "storageType": {
            "$ref": "#/components/schemas/BackupStorageType"
          },
          "storageParams": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/ItemKeyValuePairObjectObject"
            },
            "description": "The backup storage parameters.",
            "nullable": true,
            "example": [
              {
                "key": "path",
                "value": "/backup"
              }
            ]
          },
          "dump": {
            "type": "boolean",
            "description": "Specifies if a dump will be created or not.",
            "example": false
          }
        },
        "additionalProperties": false,
        "description": "The backup parameters."
      },
      "BackupHistoryRecord": {
        "required": [
          "createdOn",
          "expiresOn",
          "fileName",
          "id",
          "storageType"
        ],
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "description": "The backup ID.",
            "format": "uuid",
            "example": "00000000-0000-0000-0000-000000000000"
          },
          "fileName": {
            "type": "string",
            "description": "The backup file name.",
            "nullable": true,
            "example": "tenant-backup"
          },
          "storageType": {
            "$ref": "#/components/schemas/BackupStorageType"
          },
          "createdOn": {
            "type": "string",
            "description": "The backup creation date.",
            "format": "date-time",
            "example": "2026-03-01T02:15:00Z"
          },
          "expiresOn": {
            "type": "string",
            "description": "The backup expiration date.",
            "format": "date-time",
            "example": "2026-03-31T02:15:00Z"
          }
        },
        "additionalProperties": false,
        "description": "The backup history parameters."
      },
      "BackupHistoryRecordArrayWrapper": {
        "type": "object",
        "properties": {
          "response": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/BackupHistoryRecord"
            }
          },
          "count": {
            "type": "integer",
            "description": "The total number of items in the response",
            "format": "int32"
          },
          "links": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "href": {
                  "type": "string",
                  "description": "URL of the link"
                },
                "action": {
                  "type": "string",
                  "description": "Action associated with the link"
                }
              }
            },
            "description": "List of links related to the response"
          },
          "status": {
            "type": "integer",
            "description": "HTTP status code of the response",
            "format": "int32"
          },
          "statusCode": {
            "type": "integer",
            "description": "HTTP status code of the response (duplicate of status)",
            "format": "int32"
          }
        }
      },
      "BackupPeriod": {
        "oneOf": [
          {
            "enum": [
              "EveryDay",
              "EveryWeek",
              "EveryMonth"
            ],
            "type": "string",
            "description": "[EveryDay - Every day, EveryWeek - Every week, EveryMonth - Every month]",
            "example": "EveryDay"
          },
          {
            "enum": [
              0,
              1,
              2
            ],
            "type": "integer",
            "description": "[0 - Every day, 1 - Every week, 2 - Every month]",
            "example": 0,
            "x-enum-varnames": [
              "EveryDay",
              "EveryWeek",
              "EveryMonth"
            ]
          }
        ],
        "description": "The backup period type.",
        "x-enum-type": "integer"
      },
      "BackupProgress": {
        "type": "object",
        "properties": {
          "isCompleted": {
            "type": "boolean",
            "description": "Specifies if the backup is completed or not.",
            "example": false
          },
          "progress": {
            "type": "integer",
            "description": "The backup progress in percentage.",
            "format": "int32",
            "example": 50
          },
          "error": {
            "type": "string",
            "description": "The backup error message.",
            "nullable": true
          },
          "warning": {
            "type": "string",
            "description": "The backup warning message.",
            "nullable": true
          },
          "link": {
            "type": "string",
            "description": "The backup link.",
            "nullable": true,
            "example": "https://example.com/backup/task_123"
          },
          "tenantId": {
            "type": "integer",
            "description": "The tenant ID.",
            "format": "int32",
            "example": 1
