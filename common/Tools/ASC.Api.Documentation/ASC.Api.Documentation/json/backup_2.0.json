    "/api/2.0/backup/getbackupscount": {
      "get": {
        "tags": [
          "Backup"
        ],
        "summary": "Get the number of backups",
        "description": "Returns the number of backups for a period of time. The default is the current calendar month.",
        "operationId": "getBackupsCount",
        "parameters": [
          {
            "name": "from",
            "in": "query",
            "description": "The from date.",
            "schema": {
              "type": "string",
              "format": "date-time",
              "example": "2025-01-01T00:00:00Z"
