    "/portal/remove": {
      "delete": {
        "tags": [
          "Portal"
        ],
        "summary": "Remove a portal",
        "description": "Deletes a portal with a name specified in the request.",
        "operationId": "remove",
        "parameters": [
          {
            "name": "PortalName",
            "in": "query",
            "description": "The portal name.",
            "schema": {
              "type": "string",
              "example": "myportal"
            }
          },
          {
            "name": "TenantId",
            "in": "query",
            "description": "The tenant ID.",
            "schema": {
              "type": "integer",
              "format": "int32",
              "example": 1
            }
          },
          {
            "name": "AffiliateId",
            "in": "query",
            "description": "The affiliate ID.",
            "schema": {
              "maxLength": 255,
              "minLength": 0,
              "type": "string",
              "example": "af123456"
            }
          },
          {
            "name": "PartnerId",
            "in": "query",
            "description": "The partner ID.",
            "schema": {
              "maxLength": 255,
              "minLength": 0,
              "type": "string",
              "example": "partner123"
            }
          },
          {
            "name": "Campaign",
            "in": "query",
            "description": "The portal campaign.",
            "schema": {
              "type": "string",
              "example": "personal"
            }
          },
          {
            "name": "FirstName",
            "in": "query",
            "description": "The first name of the portal owner.",
            "schema": {
              "maxLength": 255,
              "minLength": 0,
              "type": "string",
              "example": "John"
            }
          },
          {
            "name": "Email",
            "in": "query",
            "description": "The email address of the portal owner.",
            "schema": {
              "maxLength": 255,
              "minLength": 0,
              "type": "string",
              "format": "email",
              "example": "john.doe@example.com"
            }
          },
          {
            "name": "Industry",
            "in": "query",
            "description": "The tenant industry.",
            "schema": {
              "type": "integer",
              "format": "int32",
              "example": 0
            }
          },
          {
            "name": "Language",
            "in": "query",
            "description": "The portal language.",
            "schema": {
              "maxLength": 7,
              "minLength": 0,
              "type": "string",
              "example": "en-US"
            }
          },
          {
            "name": "LastName",
            "in": "query",
            "description": "The last name of the portal owner.",
            "schema": {
              "maxLength": 255,
              "minLength": 0,
              "type": "string",
              "example": "Doe"
            }
          },
          {
            "name": "Module",
            "in": "query",
            "description": "The name for the storage module to be configured.",
            "schema": {
              "maxLength": 38,
              "minLength": 0,
              "type": "string",
              "example": "files"
            }
          },
          {
            "name": "Password",
            "in": "query",
            "description": "The password of the portal owner.",
            "schema": {
              "maxLength": 30,
              "minLength": 0,
              "type": "string",
              "example": "yourPassword1!"
            }
          },
          {
            "name": "PasswordHash",
            "in": "query",
            "description": "The password hash.",
            "schema": {
              "type": "string",
              "example": "VGhpcyBpcyBhIHRlc3Q="
            }
          },
          {
            "name": "Phone",
            "in": "query",
            "description": "The phone numberr of the portal owner.",
            "schema": {
              "maxLength": 32,
              "minLength": 0,
              "type": "string",
              "example": "+15551234567"
            }
          },
          {
            "name": "RecaptchaResponse",
            "in": "query",
            "description": "The user's response to the CAPTCHA challenge.",
            "schema": {
              "type": "string",
              "example": "03AGdBq24rvY..."
            }
          },
          {
            "name": "RecaptchaType",
            "in": "query",
            "description": "The type of CAPTCHA validation used.",
            "schema": {
              "$ref": "#/components/schemas/RecaptchaType"
            },
            "example": 0
          },
          {
            "name": "Region",
            "in": "query",
            "description": "The portal region.",
            "schema": {
              "maxLength": 20,
              "minLength": 0,
              "type": "string",
              "example": "us-east"
            }
          },
          {
            "name": "AWSRegion",
            "in": "query",
            "description": "The portal AWS region.",
            "schema": {
              "type": "string",
              "example": "us-east-1"
            }
          },
          {
            "name": "Status",
            "in": "query",
            "description": "The tenant status.",
            "schema": {
              "$ref": "#/components/schemas/TenantStatus"
            },
            "example": 0
          },
          {
            "name": "SkipWelcome",
            "in": "query",
            "description": "Specifies whether to send the welcome email to the user or not.",
            "schema": {
              "type": "boolean",
              "example": false
            }
          },
          {
            "name": "TimeZoneName",
            "in": "query",
            "description": "The portal time zone name.",
            "schema": {
              "maxLength": 255,
              "minLength": 0,
              "type": "string",
              "example": "UTC"
            }
          },
          {
            "name": "Spam",
            "in": "query",
            "description": "Specifies if the ONLYOFFICE newsletter is allowed or not.",
            "schema": {
              "type": "boolean",
              "example": true
            }
          },
          {
            "name": "Calls",
            "in": "query",
            "description": "Specifies if the calls are available for the current tenant or not.",
            "schema": {
              "type": "boolean",
              "example": true
            }
          },
          {
            "name": "AppKey",
            "in": "query",
            "description": "The application key.",
            "schema": {
              "type": "string",
              "example": "app-key-123"
            }
          },
          {
            "name": "LimitedAccessSpace",
            "in": "query",
            "description": "Specifies whether the access to the space management is limited or not.",
            "schema": {
              "type": "boolean",
              "example": false
            }
          },
          {
            "name": "ThirdPartyProfile",
            "in": "query",
            "description": "The serialized third party profile.",
            "schema": {
              "type": "string",
              "example": "{\"id\":\"12345\",\"provider\":\"google\"}"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Ok",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/IActionResultWrapper"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized"
          }
        },
        "security": [
          {
            "asc_auth_key": [
              "read",
              "write"
            ]
          },
          {
            "Bearer": [ ]
          },
          {
            "ApiKeyBearer": [
              "read",
              "write"
            ]
          },
          {
            "Basic": [ ]
          },
          {
            "OAuth2": [
              "read",
              "write"
            ]
          },
          {
            "OpenId": [ ]
          }
        ]
      }
    },
